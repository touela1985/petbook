# Normalize all text files to LF in the repo, regardless of OS settings.
* text=auto eol=lf

# Dart / Flutter source
*.dart text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.html text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.xml  text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.sh   text eol=lf

# Binary — never touch line endings
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.ttf    binary
*.otf    binary
*.woff   binary
*.woff2  binary
*.zip    binary
*.jar    binary
*.keystore binary
*.jks    binary
*.apk    binary
*.aab    binary
