rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile images — stored as profiles/{uid}.jpg
    // The uid is embedded in the filename, so write ownership CAN be enforced.
    // Any authenticated user can read (profile photos may appear in listings).
    match /profiles/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName == (request.auth.uid + '.jpg');
    }

    // Pet images — stored as pets/{petId}.jpg where petId is a UUID.
    // Ownership cannot be enforced at the path level (no uid in path).
    // Restricted to authenticated users only.
    match /pets/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Lost pet report images — stored as lost_pets/{reportId}.jpg (UUID path).
    // Ownership not enforceable at path level.
    match /lost_pets/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Found pet report images — stored as found_pets/{reportId}.jpg (UUID path).
    // Ownership not enforceable at path level.
    match /found_pets/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Adoption pet images — stored as adoptions/{adoptionId}.jpg (UUID path).
    // Ownership not enforceable at path level.
    match /adoptions/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Community item images — stored as community/{itemId}.jpg (UUID path).
    // Community data is local-only in the current app but the Storage path
    // exists in StorageService and must remain accessible.
    match /community/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
